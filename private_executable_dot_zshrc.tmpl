# --- IMPORTS (Usando $HOME para compatibilidad) ---
[[ -f $HOME/.zsh/aliases.zsh ]] && source $HOME/.zsh/aliases.zsh
[[ -f $HOME/.zsh/starship.zsh ]] && source $HOME/.zsh/starship.zsh
[[ -f $HOME/.zsh/venvchecker.zsh ]] && source $HOME/.zsh/venvchecker.zsh

# --- OH-MY-ZSH ---
export ZSH="$HOME/.oh-my-zsh"

{{- if eq .chezmoi.os "darwin" }}
fpath=(/opt/homebrew/share/zsh/site-functions $fpath)
{{- end }}
fpath=($HOME/.zsh/osx-zsh-completions/ $fpath)

# Init
autoload -Uz compinit; compinit
# compinit -d ~/.zcompdump
source $ZSH/custom/plugins/fzf-tab/fzf-tab.plugin.zsh

plugins=(
  zsh-autosuggestions
  F-Sy-H
  sudo
  fzf
  zoxide
  fzf-tab
  ssh
  # docker
)

source $ZSH/oh-my-zsh.sh


# --- KEYBINDINGS & HISTORY ---
bindkey -e
bindkey '^p' history-search-backward
bindkey '^n' history-search-forward
bindkey '^[w' kill-region

# History
HISTSIZE=5000
HISTFILE=$HOME/.zsh_history
SAVEHIST=$HISTSIZE
HISTDUP=erase
setopt appendhistory sharehistory hist_ignore_space hist_ignore_all_dups hist_save_no_dups hist_ignore_dups hist_find_no_dups

# --- COMPLETION STYLING (FIXED FOR MAC) ---
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'
zstyle ':completion:*' menu no

# FIX: we use  'eza' instead 'ls' to avoid flag issues with colors in macOS
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath'
zstyle ':fzf-tab:complete:__zoxide_z:*' fzf-preview 'eza -1 --color=always $realpath'

zstyle ':completion:*:*:docker:*' option-stacking yes
zstyle ':completion:*:*:docker-*:*' option-stacking yes

# --- ALIASES ---
alias ls='eza -a --icons --group-directories-first'
alias ll="eza -lah --icons --group-directories-first"


# Load Starship
eval "$(starship init zsh)"
# Load thef*ck plugin
eval $(thefuck --alias)
eval "$(fzf --zsh)"
eval "$(zoxide init --cmd cd zsh)"


 #Suffix Aliases - Open Files by Extension
# -------------------------------------------
# Just type the filename to open it with the associated program
alias -s json=jless
alias -s md=bat
alias -s go='$EDITOR'
alias -s rs='$EDITOR'
alias -s txt=bat
alias -s log=bat
alias -s py='$EDITOR'
alias -s js='$EDITOR'
alias -s ts='$EDITOR'

{{- if eq .chezmoi.os "darwin" }}
alias -s html=open # Mac usa 'open'
{{- else }}
alias -s html=xdg-open # Linux usa 'xdg-open'
{{- end }}

# --- EDITOR BUFFER ---
autoload -Uz edit-command-line
zle -N edit-command-line
bindkey '^x^e' edit-command-line

# --- PATHS & EXPORTS (FIXED PATHS) ---
export PATH=$PATH:$HOME/go/bin

# Bun
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# Pipx & Local Bin
export PATH="$PATH:$HOME/.local/bin"

# --- OS SPECIFIC LOGIC ---
{{- if eq .chezmoi.os "darwin" }}
# === MAC OS CONFIG ===
if [[ -f /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi
# Mac Aliases
alias flushdns="sudo dscacheutil -flushcache; sudo killall -HUP mDNSResponder"


{{- else if eq .chezmoi.os "linux" }}
# === ARCH LINUX CONFIG ===
# Exegol
alias exegol='sudo -E $HOME/.local/bin/exegol'
alias pac="sudo pacman"

{{- end }}
