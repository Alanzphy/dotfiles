[user]
	email = alanzphy@gmail.com
	name = Alan Ruiz
	signingkey = /home/alanz/.ssh/ssh-github.pub
[init]
	defaultBranch = main

[alias]
 	lg = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset)%C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)' --all
 	s = status --short --branch
 	shove = push --force-with-lease --force-if-includes
[status]
  branch = true
  showStash = true
[pull]
  rebase = true
  default = current
  followTags = true
[push]
  autoSetupRemote = true
  default = current
[core]
	editor = nvim
	excludesfile = ~/.gitignore_global
[credential]
	helper = cache
[rebase]
	autoStash = true
[gpg]
  format = ssh
[commit]
  gpgSign = true
[help]
	autocorrect = prompt
[credential]
{{- if eq .chezmoi.os "linux" }}
	helper = cache
{{- else if eq .chezmoi.os "darwin" }}
	helper = osxkeychain
{{- end }}
[credential "https://github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential
