[user]
	email = alanzphy@gmail.com
	name = Alan Ruiz
[init]
	defaultBranch = main

[alias]
 	lg = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset)%C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)' --all
 	s = status --short --branch
 	shove = push --force-with-lease --force-if-includes
[status]
  branch = true
  showStash = true
[pull]
  rebase = true
  default = current
  followTags = true
[push]
  autoSetupRemote = true
  default = current
[core]
	editor = nvim
	excludesfile = ~/.gitignore_global
[credential]
	helper = cache
[rebase]
	autoStash = true
#[url "ssh://git@github.com/"]
#	insteadOf = https://github.com/
[gpg]
	format = ssh
[help]
	autocorrect = prompt
