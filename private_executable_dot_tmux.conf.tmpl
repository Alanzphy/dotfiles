# Automatically choose split direction with longest side scheme
bind-key -n M-Enter if-shell '[ "$(expr 25 \* #{pane_height} / 10 )" -lt "#{pane_width}" ]' \
    'split-pane -h -c "#{pane_current_path}"' \
    'split-pane -v -c "#{pane_current_path}"'

# Kill pane
bind-key -n M-Q kill-pane

# Create new session
#bind-key s new-session -s

# set vi-mode
set-window-option -g mode-keys vi
# Copy mode keybinds
bind-key -T copy-mode-vi v send-keys -X begin-selection
bind-key -T copy-mode-vi C-v send-keys -X rectangle-toggle

# --- CLIPBOARD INTELLIGENT CONFIG ---

{{- if eq .chezmoi.os "darwin" }}
# Config para MAC (Usa pbcopy)
bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "pbcopy"
bind-key -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "pbcopy"
{{- else if eq .chezmoi.os "linux" }}
# Config para LINUX (Usa xclip o wl-copy)
# Si usas Wayland (Hyprland/Sway), cambia 'xclip -selection clipboard' por 'wl-copy'
bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "xclip -selection clipboard"
bind-key -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "xclip -selection clipboard"
{{- end }}
